  "keyFeatures": [
    "Framer Motion-compatible API for Svelte 5",
    "motion.<tag> components for all standard HTML/SVG elements",
    "AnimatePresence for enter/exit animations with sync, wait, and popLayout modes",
    "Variants system with string keys and context inheritance",
    "Gesture support: whileHover, whileTap, whileFocus, whileInView, drag",
    "FLIP layout animations with layout and layoutId props",
    "Spring physics via useSpring and transition type: 'spring'",
    "Utility hooks: useMotionValue, useTransform, useSpring, useTime, useScroll",
    "SSR-safe: initial state rendered server-side, hydration without flicker",
    "TypeScript-first with full type exports"
  ],
  "publicApiSurface": [
